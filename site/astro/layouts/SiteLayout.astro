---
const { title = 'Excalibur.js', description = 'Your friendly TypeScript 2D game engine for the web.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/img/favicon.ico" />
    <script is:inline defer data-domain="excaliburjs.com" src="https://plausible.io/js/script.js"></script>
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">Excalibur.js</a>
      <nav aria-label="Main navigation">
        <a href="/docs/">Docs</a>
        <a href="/api/">API</a>
        <a href="/blog/">Blog</a>
        <a href="/samples/">Samples</a>
        <a href="/showcase/">Showcase</a>
        <a href="/donate/">Donate</a>
        <a href="https://github.com/excaliburjs/Excalibur">GitHub</a>
      </nav>
    </header>
    <slot />
    <footer class="site-footer">
      <p>Copyright © {new Date().getFullYear()} Excalibur.js Project.</p>
    </footer>
  </body>
</html>

<style>
  :global(body) {
    color: #18232f;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    line-height: 1.6;
    margin: 0;
  }

  :global(a) {
    color: #2185d0;
  }

  .site-header,
  .site-footer {
    align-items: center;
    border-bottom: 1px solid #d8e1ea;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    padding: 1rem max(1rem, calc((100vw - 1120px) / 2));
  }

  .site-footer {
    border-bottom: 0;
    border-top: 1px solid #d8e1ea;
    margin-top: 4rem;
  }

  .brand {
    color: #18232f;
    font-weight: 800;
    text-decoration: none;
    white-space: nowrap;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    justify-content: flex-end;
  }

  nav a {
    color: #425466;
    text-decoration: none;
  }

  @media (max-width: 680px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }

    nav {
      justify-content: flex-start;
    }
  }
</style>
